# ==============================================================================
#  Customer Churn Intelligence Platform — .gitignore
# ==============================================================================


# ── PyInstaller build outputs ──────────────────────────────────────────────────
dist/
build/
*.spec


# ── Python cache ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd


# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/


# ── Distribution / packaging artefacts ────────────────────────────────────────
*.egg-info/
*.dist-info/
*.egg


# ── Output reports & test datasets ────────────────────────────────────────────
# Exclude any Excel reports or data files generated / used during testing.
# Remove the lines below if you intentionally want to commit sample data.
*.xlsx
*.xls
*.xlsm
*.xlsb
*.ods
*.csv
*.tsv
*.bak                   # Excel lock-conflict backup files


# ── IDE / Editor files ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo


# ── OS generated files ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db


# ── Jupyter Notebook checkpoints ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb


# ── Python version managers ────────────────────────────────────────────────────
.python-version         # pyenv
.tool-versions          # asdf


# ── Temporary / log files ──────────────────────────────────────────────────────
*.log
*.tmp
*.temp
