# ==============================================================================
#  Customer Churn Intelligence Platform — GUI Edition
#  .gitignore
# ==============================================================================


# ── PyInstaller build outputs ──────────────────────────────────────────────────
dist/
build/
*.spec


# ── Python cache ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd


# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/


# ── Distribution / packaging artefacts ────────────────────────────────────────
*.egg-info/
*.dist-info/
*.egg


# ── Output reports & test datasets ────────────────────────────────────────────
# Excludes Excel reports generated by the app and any input datasets used for
# testing. Remove specific lines below if you want to commit sample data.
*.xlsx
*.xls
*.xlsm
*.xlsb
*.ods
*.csv
*.tsv
*.bak                   # Excel lock-conflict backup files created by retry logic


# ── IDE / Editor files ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo


# ── OS generated files ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db


# ── Jupyter Notebook checkpoints ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb


# ── Python version managers ────────────────────────────────────────────────────
.python-version         # pyenv
.tool-versions          # asdf


# ── Temporary / log files ──────────────────────────────────────────────────────
*.log
*.tmp
*.temp
