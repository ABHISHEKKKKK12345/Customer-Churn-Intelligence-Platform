# ==============================================================================
#  .gitignore — Customer Churn Intelligence Platform
# ==============================================================================


# ── Python cache & compiled files ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc


# ── Virtual environments ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/
.Python
pip-selfcheck.json


# ── Distribution / build artefacts ─────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
MANIFEST
*.spec


# ── PyInstaller output ──────────────────────────────────────────────────────────
# (generated when building the .exe)
*.exe
*.app
*.dmg


# ── Output reports generated by the app ────────────────────────────────────────
*_Churn_Report.xlsx
Churn_Analytics_Report.xlsx
*_Churn_Analytics_*.xlsx


# ── Dataset / data files (keep out of version control) ─────────────────────────
*.csv
*.xlsx
*.xls
*.xlsm
*.xlsb
*.ods
*.tsv
*.txt
# Un-ignore this file specifically so requirements.txt stays tracked:
!requirements.txt


# ── IDE / editor artefacts ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini


# ── Jupyter notebooks (if used for prototyping) ────────────────────────────────
.ipynb_checkpoints/
*.ipynb


# ── Testing ────────────────────────────────────────────────────────────────────
.pytest_cache/
.tox/
.coverage
coverage.xml
htmlcov/
*.log


# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
secrets.py
config_local.py
